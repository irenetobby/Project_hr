import joblib
from sklearn.metrics import mean_absolute_error, r2_score

# 1. Assume 'y_test' is your actual log-salaries 
# and 'y_pred' is what your model predicted.
# (If your model predicts log-scale, calculate metrics on the log-scale)

mae = mean_absolute_error(y_test, y_pred)
r2 = r2_score(y_test, y_pred)

# Note: Your Streamlit code looks for 'accuracy'. 
# In regression, some use (1 - Mean Percentage Error) as 'accuracy',
# but for now, let's just provide the keys the app expects:
metrics_dict = {
    'accuracy': r2 * 100,  # Using R2 as a proxy for "Accuracy" percentage
    'r2': r2,
    'mae': mae
}

# 2. Save the dictionary
joblib.dump(metrics_dict, 'metrics.pkl')

print("metrics.pkl created successfully!")
print(f"Values saved: {metrics_dict}")