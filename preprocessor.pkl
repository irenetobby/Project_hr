import pandas as pd
import joblib
from sklearn.compose import ColumnTransformer
from sklearn.preprocessing import OneHotEncoder, OrdinalEncoder

# Sample data to "fit" the preprocessor (replace with your actual data)
data = {
    'Department': ['Sales', 'Engineering', 'HR', 'Marketing', 'Finance'],
    'Job_Level': ['Junior', 'Mid', 'Senior', 'Lead', 'Executive']
}
df = pd.DataFrame(data)

# Define the transformations based on your app's requirements
preprocessor = ColumnTransformer(
    transformers=[
        # 'ohe_dept' must match your st.selectbox logic
        ('ohe_dept', OneHotEncoder(sparse_output=False), ['Department']),
        # 'oe_joblevel' must match your st.selectbox logic
        ('oe_joblevel', OrdinalEncoder(), ['Job_Level'])
    ]
)

# Fit the preprocessor
preprocessor.fit(df)

# Save it as preprocessor.pkl
joblib.dump(preprocessor, 'preprocessor.pkl')
print("preprocessor.pkl has been created successfully!")